    <!-- 核心业务逻辑脚本 -->
    <script>
        function showLoading() { document.getElementById('loading').classList.add('active'); }
        function hideLoading() { document.getElementById('loading').classList.remove('active'); }
        
        // ==================== 主题切换逻辑 ====================
        function updateThemeIcon() {
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            const icon = document.querySelector('#themeToggleBtn i');
            if(icon) {
                icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
            }
        }

        function toggleTheme() {
            const currentTheme = document.documentElement.getAttribute('data-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
            
            document.documentElement.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            updateThemeIcon();
            showNotification(newTheme === 'dark' ? '已切换至深色模式' : '已切换至浅色模式', 2000);
        }

        // 监听系统主题变化
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', e => {
            if (!localStorage.getItem('theme')) {
                document.documentElement.setAttribute('data-theme', e.matches ? 'dark' : 'light');
                updateThemeIcon();
            }
        });

        // 控制侧边栏展开/关闭
        function toggleSidebar() {
            document.getElementById('menuToggle').classList.toggle('open');
            document.getElementById('sidebar').classList.toggle('open');
            document.getElementById('sidebarOverlay').classList.toggle('show');
        }

        function formatDateTime(date) {
            const year = date.getFullYear();
            const month = date.getMonth() + 1;
            const day = date.getDate();
            const weekdays = ['星期日', '星期一', '星期二', '星期三', '星期四', '星期五', '星期六'];
            const weekday = weekdays[date.getDay()];
            const hour = date.getHours().toString().padStart(2, '0');
            const minute = date.getMinutes().toString().padStart(2, '0');
            const second = date.getSeconds().toString().padStart(2, '0');
            return `${year}年${month}月${day}日${weekday} ${hour}:${minute}:${second}`;
        }
        
        function simulateLatency() {
            const baseLatency = 35;
            const randomFluctuation = Math.floor(Math.random() * 25);
            const currentLatency = baseLatency + randomFluctuation;
            let latencyClass = currentLatency < 50 ? 'good' : (currentLatency < 100 ? 'medium' : 'poor');
            return { value: currentLatency, class: latencyClass };
        }
        
        function updateStats() {
            const transactionCountElement = document.getElementById('transactionCount');
            if(transactionCountElement) {
                const currentTransactionCount = parseInt(transactionCountElement.textContent.replace('K+', '000')) || 40000;
                const newTransactionCount = currentTransactionCount + Math.floor(Math.random() * 5);
                transactionCountElement.textContent = Math.floor(newTransactionCount / 1000) + 'K+';
            }
        }
        
        function updateDisplay() {
            const now = new Date();
            document.getElementById('datetime').textContent = formatDateTime(now);
            
            const latency = simulateLatency();
            const latencyElement = document.getElementById('latency');
            latencyElement.textContent = `网络延迟: ${latency.value}ms`;
            
            latencyElement.style.color = latency.class === 'good' ? '#2e7d32' : (latency.class === 'medium' ? '#f57c00' : '#d32f2f');
            latencyElement.style.background = latency.class === 'good' ? 'rgba(46, 125, 50, 0.1)' : (latency.class === 'medium' ? 'rgba(245, 124, 0, 0.1)' : 'rgba(211, 47, 47, 0.1)');
        }
        
        function showNotification(message, duration = 3000) {
            const notification = document.getElementById('notification');
            const notificationMessage = document.getElementById('notificationMessage');
            notificationMessage.textContent = message;
            notification.classList.add('show');
            setTimeout(() => { notification.classList.remove('show'); }, duration);
        }
        
        function openLink(url, button) {
            if (button) {
                const originalHTML = button.innerHTML;
                button.innerHTML = '<i class="fas fa-spinner fa-spin"></i><span>加载中...</span>';
                button.disabled = true;
                setTimeout(() => { button.innerHTML = originalHTML; button.disabled = false; }, 2000);
            }
            window.open(url, '_blank');
        }
        
        function shareProfile() {
            const profileUrl = window.location.href;
            const profileTitle = 'lhy - Telegram官方账号';
            if (navigator.share) {
                navigator.share({ title: profileTitle, text: '查看lhy的Telegram官方账号和服务信息', url: profileUrl })
                .then(() => showNotification('分享成功！'))
                .catch(() => copyToClipboard(profileUrl));
            } else {
                copyToClipboard(profileUrl);
            }
        }
        
        function copyToClipboard(text) {
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(text).then(() => showNotification('链接已复制到剪贴板')).catch(() => fallbackCopyToClipboard(text));
            } else {
                fallbackCopyToClipboard(text);
            }
        }
        
        function fallbackCopyToClipboard(text) {
            const textArea = document.createElement('textarea');
            textArea.value = text;
            textArea.style.position = 'fixed';
            textArea.style.opacity = '0';
            document.body.appendChild(textArea);
            textArea.focus();
            textArea.select();
            try {
                const successful = document.execCommand('copy');
                showNotification(successful ? '链接已复制到剪贴板' : '复制失败，请手动复制');
            } catch (err) {
                showNotification('复制失败，请手动复制链接');
            }
            document.body.removeChild(textArea);
        }
        
        document.addEventListener('DOMContentLoaded', function() {
            document.body.style.opacity = '0';
            showLoading();
            updateThemeIcon(); // 初始化主题图标
            
            setTimeout(() => {
                updateDisplay();
                updateStats();
                
                const now = new Date();
                document.getElementById('lastUpdated').textContent = `${now.getFullYear()}-${(now.getMonth()+1).toString().padStart(2, '0')}-${now.getDate().toString().padStart(2, '0')}`;
                
                hideLoading();
                document.body.style.transition = 'opacity 0.5s';
                document.body.style.opacity = '1';
            }, 800);
            
            setInterval(updateDisplay, 1000);
            setInterval(updateStats, 30000);
        });
    </script>
