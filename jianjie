<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="description" content="lhy的Telegram账号和官方服务入口">
    <meta name="keywords" content="Telegram, TG账号, lhy, 源渠, 纸飞机">
    <meta name="theme-color" content="#1976d2">
    <title>lhy - Telegram官方账号</title>
    <link rel="icon" href="https://avatars.githubusercontent.com/u/190176824">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- 尽早执行主题初始化，防止页面闪烁 -->
    <script>
        (function() {
            var savedTheme = localStorage.getItem('theme');
            var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
                document.documentElement.setAttribute('data-theme', 'dark');
            } else {
                document.documentElement.setAttribute('data-theme', 'light');
            }
        })();
    </script>

    <style>
        :root {
            --primary-color: #1976d2;
            --primary-light: #2196f3;
            --secondary-color: #29b6f6;
            --accent-color: #1565c0;
            --success-color: #2e7d32;
            --warning-color: #ff9800;
            --danger-color: #d32f2f;
            --text-primary: #333333;
            --text-secondary: #555555;
            --text-light: #666666;
            --bg-gradient-start: #e0f7fa;
            --bg-gradient-end: #bbdefb;
            --card-bg: rgba(255, 255, 255, 0.98);
            --shadow-color: rgba(0, 0, 150, 0.12);
            --shadow-hover: rgba(0, 0, 150, 0.2);
            --border-radius: 24px;
            --border-radius-sm: 16px;
            --transition-speed: 0.3s;
            --safe-area-top: env(safe-area-inset-top, 0);
            --safe-area-bottom: env(safe-area-inset-bottom, 0);
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }
        
        html {
            font-size: 16px;
            scroll-behavior: smooth;
            transition: background-color 0.3s ease;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Microsoft YaHei", "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: linear-gradient(135deg, var(--bg-gradient-start), var(--bg-gradient-end));
    
            /* 修改此处 */
            min-height: 100vh;
            min-height: -webkit-fill-available;
            height: auto; /* 关键：确保高度随内容自动撑开 */
    
            display: flex;
            justify-content: center;
            align-items: flex-start; /* 将 center 改为 flex-start，让内容从顶部开始，避免长页面在短屏上错位 */
    
            padding: 20px;
            padding-top: calc(20px + var(--safe-area-top));
            padding-bottom: calc(20px + var(--safe-area-bottom));
            color: var(--text-primary);
            overflow-y: auto; /* 确保内容溢出时可以滚动 */
            transition: color 0.3s ease;
        }

        /* ==================== 左上角三道杠汉堡按钮 ==================== */
        .menu-toggle {
            position: fixed;
            top: calc(20px + var(--safe-area-top));
            left: 20px;
            width: 45px;
            height: 45px;
            background: var(--card-bg);
            border: 1px solid rgba(41, 182, 246, 0.2);
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 6px;
            cursor: pointer;
            z-index: 2000;
            box-shadow: 0 4px 12px var(--shadow-color);
            transition: all 0.3s ease;
        }
        .menu-toggle:hover {
            transform: scale(1.05);
            background: var(--card-bg);
        }
        .menu-toggle span {
            display: block;
            width: 24px;
            height: 3px;
            background: var(--primary-color);
            border-radius: 2px;
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        }
        .menu-toggle.open span:nth-child(1) { transform: translateY(9px) rotate(45deg); }
        .menu-toggle.open span:nth-child(2) { opacity: 0; transform: translateX(-10px); }
        .menu-toggle.open span:nth-child(3) { transform: translateY(-9px) rotate(-45deg); }

        /* ==================== 新增：右上角主题切换按钮 ==================== */
        .theme-toggle {
            position: fixed;
            top: calc(20px + var(--safe-area-top));
            right: 20px;
            width: 45px;
            height: 45px;
            background: var(--card-bg);
            border: 1px solid rgba(41, 182, 246, 0.2);
            border-radius: 12px;
            display: flex;
            justify-content: center;
            align-items: center;
            cursor: pointer;
            z-index: 2000;
            box-shadow: 0 4px 12px var(--shadow-color);
            transition: all 0.3s ease;
            color: var(--primary-color);
            font-size: 1.2rem;
        }
        .theme-toggle:hover {
            transform: scale(1.05);
        }

        /* ==================== 侧边抽屉菜单 ==================== */
        .sidebar {
            position: fixed;
            top: 0;
            left: -320px;
            width: 300px;
            height: 100vh;
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            box-shadow: 5px 0 30px var(--shadow-color);
            z-index: 1900;
            transition: left 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
            padding: calc(80px + var(--safe-area-top)) 20px 20px 20px;
            display: flex;
            flex-direction: column;
            border-right: 1px solid rgba(255, 255, 255, 0.3);
        }
        .sidebar.open { left: 0; }

        .sidebar-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(3px);
            -webkit-backdrop-filter: blur(3px);
            z-index: 1800;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.4s ease;
        }
        .sidebar-overlay.show { opacity: 1; pointer-events: auto; }

        .sidebar-brand {
            font-size: 1.3rem;
            font-weight: 800;
            color: var(--accent-color);
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 1px solid rgba(41, 182, 246, 0.15);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .sidebar-menu-title {
            font-size: 0.85rem;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 10px;
            padding-left: 5px;
        }
        .sidebar-nav { display: flex; flex-direction: column; gap: 8px; }
        .sidebar-item {
            display: flex; align-items: center; justify-content: space-between;
            padding: 14px 18px; color: var(--text-primary); text-decoration: none;
            font-size: 1rem; font-weight: 600; border-radius: 12px;
            background: rgba(41, 182, 246, 0.04); border: 1px solid rgba(41, 182, 246, 0.05);
            transition: all 0.25s ease;
        }
        .sidebar-item:hover {
            background: rgba(41, 182, 246, 0.12);
            color: var(--accent-color);
            padding-left: 24px;
            border-color: rgba(41, 182, 246, 0.2);
        }
        .sidebar-item i.item-icon { width: 20px; font-size: 1.1rem; color: var(--primary-light); }
        .sidebar-item .item-content { display: flex; align-items: center; gap: 12px; }
        .sidebar-item i.arrow-icon { font-size: 0.8rem; opacity: 0.6; transition: transform 0.2s; }
        .sidebar-item:hover i.arrow-icon { transform: translateX(3px); }
        
        /* 响应式媒体查询 */
        @media (max-width: 768px) {
            html { font-size: 12px; }
            body { padding: 15px; padding-top: calc(15px + var(--safe-area-top)); padding-bottom: calc(15px + var(--safe-area-bottom)); }
            .menu-toggle { top: calc(15px + var(--safe-area-top)); left: 15px; width: 40px; height: 40px; gap: 5px; }
            .theme-toggle { top: calc(15px + var(--safe-area-top)); right: 15px; width: 40px; height: 40px; font-size: 1.1rem; }
            .menu-toggle span { width: 20px; height: 2.5px; }
            .menu-toggle.open span:nth-child(1) { transform: translateY(7.5px) rotate(45deg); }
            .menu-toggle.open span:nth-child(3) { transform: translateY(-7.5px) rotate(-45deg); }
        }
        
        @media (max-width: 480px) {
            html { font-size: 13px; }
            body { padding: 12px; padding-top: calc(12px + var(--safe-area-top)); padding-bottom: calc(12px + var(--safe-area-bottom)); }
        }
        
        .container {
            width: 100%;
            max-width: 500px;
            min-width: 280px;
            margin: 0 auto;
            /* 移除 animation 中的 transform 移动，只保留渐变，避免手机端出现诡异留白 */
            animation: fadeIn 0.8s cubic-bezier(0.22, 0.61, 0.36, 1);
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(30px) scale(0.95); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
        
        .card {
            background: var(--card-bg);
            border-radius: var(--border-radius);
            padding: clamp(25px, 5vw, 35px);
            box-shadow: 0 10px 30px var(--shadow-color), 0 1px 3px rgba(0, 0, 0, 0.05), inset 0 0 0 1px rgba(255, 255, 255, 0.8);
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
        }
        
        .card::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.9) 8%, transparent 8%);
            background-size: 25px 25px;
            transform: rotate(30deg);
            opacity: 0.05;
            z-index: 0;
            animation: bgMove 30s linear infinite;
        }
        
        @keyframes bgMove {
            0% { transform: rotate(30deg) translate(0, 0); }
            100% { transform: rotate(390deg) translate(0, 0); }
        }
        
        .profile-header {
            position: relative;
            z-index: 1;
            margin-bottom: 25px;
            text-align: center;
        }
        
        .avatar-container {
            position: relative;
            width: 130px;
            height: 130px;
            margin: 0 auto 25px;
        }

        @media (max-height: 700px) {
         .card {
             padding: 15px; /* 在高度受限的手机上减小内边距 */
         }
         .profile-header {
             margin-bottom: 15px;
         }
         .avatar-container {
            width: 100px;
            height: 100px;
            margin-bottom: 15px;
         }
        }
        
        @media (max-width: 480px) {
            .avatar-container { width: 110px; height: 110px; margin-bottom: 20px; }
        }
        
        .avatar {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            border: 5px solid var(--secondary-color);
            overflow: hidden;
            position: relative;
            box-shadow: 0 10px 25px rgba(33, 150, 243, 0.3), 0 0 0 4px rgba(255, 255, 255, 0.8);
            transition: transform var(--transition-speed), box-shadow var(--transition-speed);
        }
        
        .avatar:hover {
            transform: scale(1.05);
            box-shadow: 0 15px 35px rgba(33, 150, 243, 0.4), 0 0 0 4px rgba(255, 255, 255, 0.9);
        }
        
        .avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }
        
        .avatar-status {
            position: absolute;
            bottom: 10px;
            right: 10px;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background-color: #4caf50;
            border: 3px solid white;
            z-index: 2;
        }
        
        .title {
            font-size: clamp(1.8rem, 5vw, 2.2rem);
            margin-bottom: 8px;
            color: transparent;
            background: linear-gradient(135deg, var(--accent-color), var(--primary-light));
            -webkit-background-clip: text;
            background-clip: text;
            font-weight: 800;
            letter-spacing: 0.5px;
            line-height: 1.2;
        }
        
        .subtitle {
            font-size: clamp(0.9rem, 3vw, 1.1rem);
            color: var(--text-secondary);
            margin-bottom: 25px;
            font-weight: 500;
            opacity: 0.9;
        }
        
        /* ========== 合并统计卡片样式 ========== */
        .stats-container {
            display: grid;
            grid-template-columns: 1fr;
            gap: 13px;
            margin-bottom: 25px;
            position: relative;
            z-index: 1;
        }

        .stat-item.combined-stats {
            padding: 12px 8px;
        }

        .stat-block {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            flex: 1;
        }

        .stat-divider {
            width: 1px;
            background: rgba(41, 182, 246, 0.2);
            margin: 0 10px;
            align-self: stretch;
        }

        /* 手机端：合并卡片占满整行 */
        @media screen and (max-width: 767px) {
            .stats-container {
                grid-template-columns: 1fr !important; /* 强制单列 */
            }
            
            .stat-item.combined-stats {
                grid-column: 1 / -1; /* 跨列 */
            }
        }

        /* 电脑端：合并卡片保持居中显示 */
        @media screen and (max-width: 767px) {
            .stats-container {
                grid-template-columns: 1fr !important; /* 强制单列 */
            }
            
            .stat-item.combined-stats {
                grid-column: 1 / -1; /* 跨列 */
            }
        }
        
        .stat-item {
            background: rgba(41, 182, 246, 0.08);
            border-radius: var(--border-radius-sm);
            padding: 15px;
            text-align: center;
            transition: transform var(--transition-speed), background-color var(--transition-speed);
            border: 1px solid rgba(41, 182, 246, 0.1);
        }
        
        .stat-item:hover {
            transform: translateY(-3px);
            background: rgba(41, 182, 246, 0.12);
        }
        
        .stat-label {
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin-bottom: 5px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 5px;
        }
        
        .stat-value { font-size: 1.3rem; font-weight: 700; color: var(--accent-color); }
        
        .datetime-container {
            background: rgba(41, 182, 246, 0.08);
            border-radius: var(--border-radius-sm);
            padding: 18px;
            margin-bottom: 25px;
            position: relative;
            z-index: 1;
            border: 1px solid rgba(41, 182, 246, 0.1);
            transition: transform var(--transition-speed);
        }
        
        .datetime-container:hover { transform: translateY(-2px); }
        
        .datetime {
            font-size: clamp(1rem, 3vw, 1.1rem);
            color: var(--text-secondary);
            font-weight: 600;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        
        .latency {
            color: var(--success-color);
            font-size: 0.9rem;
            font-weight: 500;
            padding: 6px 15px;
            background: rgba(46, 125, 50, 0.1);
            border-radius: 20px;
            display: inline-block;
            transition: all var(--transition-speed);
        }
        
        .channel-info {
            background: linear-gradient(135deg, rgba(41, 182, 246, 0.12), rgba(33, 150, 243, 0.08));
            border-radius: var(--border-radius-sm);
            padding: 22px;
            margin: 30px 0;
            position: relative;
            z-index: 1;
            border-left: 5px solid var(--primary-light);
            transition: transform var(--transition-speed);
            box-shadow: 0 5px 15px rgba(33, 150, 243, 0.1);
        }
        
        .channel-info:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(33, 150, 243, 0.15);
        }
        
        .channel-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 15px; }
        .channel-name { font-weight: 800; color: var(--accent-color); font-size: 1.2rem; display: flex; align-items: center; gap: 8px; }
        .channel-badge { background: var(--primary-light); color: white; padding: 3px 10px; border-radius: 20px; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.5px; }
        .channel-desc { font-size: 1rem; color: var(--text-secondary); line-height: 1.7; font-weight: 500; }
        .channel-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 15px; }
        .tag { background: rgba(41, 182, 246, 0.15); color: var(--accent-color); padding: 5px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: 600; display: inline-block; }
        
        .action-buttons { display: flex; flex-direction: column; gap: 18px; margin: 35px 0; position: relative; z-index: 1; }
        
        .action-btn {
            display: flex; align-items: center; justify-content: center; gap: 12px; width: 100%; padding: 18px;
            background: linear-gradient(135deg, var(--primary-light), var(--primary-color)); color: white; border: none;
            border-radius: 50px; font-size: 1.1rem; font-weight: 700; cursor: pointer; transition: all var(--transition-speed);
            box-shadow: 0 6px 20px rgba(33, 150, 243, 0.3); position: relative; overflow: hidden;
        }
        
        .action-btn::before {
            content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.25), transparent); transition: left 0.7s;
        }
        
        .action-btn:hover::before { left: 100%; }
        .action-btn:hover { transform: translateY(-4px); box-shadow: 0 12px 25px rgba(33, 150, 243, 0.4); }
        .action-btn:active { transform: translateY(-1px); }
        .action-btn:disabled { opacity: 0.7; cursor: not-allowed; }
        .action-btn:nth-child(2) { background: linear-gradient(135deg, #4caf50, #2e7d32); box-shadow: 0 6px 20px rgba(76, 175, 80, 0.3); }
        .action-btn:nth-child(2):hover { box-shadow: 0 12px 25px rgba(76, 175, 80, 0.4); }
        .btn-icon { font-size: 1.2rem; }
        
        .quick-links { display: flex; justify-content: center; gap: 20px; margin: 25px 0; position: relative; z-index: 1; }
        
        .quick-link {
            display: flex; flex-direction: column; align-items: center; justify-content: center; width: 60px; height: 60px;
            background: rgba(41, 182, 246, 0.1); border-radius: 50%; color: var(--accent-color); text-decoration: none;
            transition: all var(--transition-speed); border: 2px solid rgba(41, 182, 246, 0.2);
        }
        
        .quick-link:hover { transform: translateY(-5px) scale(1.1); background: rgba(41, 182, 246, 0.2); box-shadow: 0 8px 20px rgba(33, 150, 243, 0.2); }
        .quick-link i { font-size: 1.5rem; margin-bottom: 5px; }
        .quick-link span { font-size: 0.7rem; font-weight: 600; }
        
        .copyright {
            font-size: 0.85rem; color: var(--text-light); margin-top: 35px; position: relative; z-index: 1;
            opacity: 0.8; text-align: center; padding-top: 20px; border-top: 1px solid rgba(0, 0, 0, 0.05);
        }
        
        .notification {
            position: fixed; bottom: 30px; right: 30px; background: white; padding: 15px 20px; border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15); z-index: 1000; transform: translateY(100px); opacity: 0;
            transition: all 0.5s ease; border-left: 4px solid var(--primary-light); max-width: 300px;
        }
        
        .notification.show { transform: translateY(0); opacity: 1; }
        .notification-message { font-size: 0.9rem; color: var(--text-primary); }
        
        /* ==================== 动态深色模式配置 ==================== */
        [data-theme="dark"] {
            --text-primary: #f0f0f0; 
            --text-secondary: #cccccc; 
            --text-light: #aaaaaa;
            --bg-gradient-start: #0a1929; 
            --bg-gradient-end: #102a43; 
            --card-bg: rgba(25, 25, 35, 0.95);
            --shadow-color: rgba(0, 0, 0, 0.3); 
            --shadow-hover: rgba(0, 0, 0, 0.5);
        }
        [data-theme="dark"] .card { border: 1px solid rgba(255, 255, 255, 0.1); }
        [data-theme="dark"] .menu-toggle, [data-theme="dark"] .theme-toggle { background: var(--card-bg); border-color: rgba(255, 255, 255, 0.1); }
        [data-theme="dark"] .theme-toggle { color: #f1c40f; } /* 太阳图标变黄色 */
        [data-theme="dark"] .sidebar { border-right: 1px solid rgba(255, 255, 255, 0.05); }
        [data-theme="dark"] .sidebar-item { background: rgba(255, 255, 255, 0.02); border-color: rgba(255, 255, 255, 0.05); }
        [data-theme="dark"] .sidebar-item:hover { background: rgba(41, 182, 246, 0.15); border-color: rgba(41, 182, 246, 0.3); }
        [data-theme="dark"] .copyright { border-top: 1px solid rgba(255, 255, 255, 0.05); }
        [data-theme="dark"] .notification { background: var(--card-bg); border-left-color: var(--primary-light); }
        
        @media (max-height: 600px) and (orientation: landscape) {
            body { align-items: flex-start; padding-top: 20px; }
            .container { max-width: 90%; }
            .card { padding: 20px; }
        }
        
        @media (hover: none) {
            .action-btn:hover { transform: none; }
            .action-btn:active { transform: scale(0.98); }
            .quick-link:hover { transform: none; }
            .quick-link:active { transform: scale(0.95); }
        }
        
        @media (min-width: 540px) and (max-width: 720px) and (min-height: 720px) {
            .container { max-width: 450px; }
        }
        
        .loading {
            display: none; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            width: 50px; height: 50px; border: 5px solid rgba(41, 182, 246, 0.2); border-radius: 50%;
            border-top-color: var(--primary-light); animation: spin 1s linear infinite; z-index: 10;
        }
        
        @keyframes spin {
            0% { transform: translate(-50%, -50%) rotate(0deg); }
            100% { transform: translate(-50%, -50%) rotate(360deg); }
        }
        
        .loading.active { display: block; }
    </style>
</head>
<body>

    <!-- 左上角三道杠按钮 -->
    <div class="menu-toggle" id="menuToggle" onclick="toggleSidebar()" title="菜单">
        <span></span>
        <span></span>
        <span></span>
    </div>

    <!-- 右上角暗色模式切换按钮 -->
    <div class="theme-toggle" id="themeToggleBtn" onclick="toggleTheme()" title="切换主题">
        <i class="fas fa-moon"></i>
